# --- myendmess.github.io (static GitHub Pages site) ---
# This is a zero-build, dependency-free site. Track the actual content
# (index.html, style/, js/, img/); ignore only local cruft and secrets.

# OS / editor cruft
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*~

# Secrets / credentials (none should ever live here, but just in case)
.env
.env.*
*.pem
*.key
secrets.*
*.local

# Logs
*.log

# Node tooling (only if you ever add a build step later)
node_modules/
npm-debug.log*
yarn-error.log*

# Claude local settings (machine-specific, not for the repo)
.claude/settings.local.json
